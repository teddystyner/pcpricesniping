# 로컬 테스트용. 이 파일을 복사해서 `.env` 로 저장하고 값을 채우세요.
# (.env 는 .gitignore 로 커밋되지 않습니다. GitHub Actions에서는 Secrets 로 설정)

# 네이버 개발자센터 > 애플리케이션 등록 > 검색 API 에서 발급
NAVER_CLIENT_ID=여기에_클라이언트_ID
NAVER_CLIENT_SECRET=여기에_클라이언트_시크릿

# 텔레그램 BotFather 에서 발급받은 봇 토큰
TELEGRAM_BOT_TOKEN=123456789:ABCdef_여기에_봇토큰
# 알림을 받을 본인 chat_id (README 참고)
TELEGRAM_CHAT_ID=123456789
